APP_NAME="Stip Me"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# PostgreSQL 16 + PostGIS 3.4
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=stipme
DB_USERNAME=stipme
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

# Redis 7 — Instance cache (port 6379, allkeys-lru)
CACHE_STORE=redis
CACHE_PREFIX=stipme_cache

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Redis 7 — Instance persistante (port 6380, noeviction)
REDIS_PERSISTENT_HOST=127.0.0.1
REDIS_PERSISTENT_PORT=6380
REDIS_PERSISTENT_PASSWORD=null

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@stip-me.com"
MAIL_FROM_NAME="${APP_NAME}"

# Cloudflare R2
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_PUBLIC=stipme-public
CLOUDFLARE_R2_BUCKET_PRIVATE=stipme-private
CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_R2_URL=

# Laravel Reverb (WebSocket)
REVERB_APP_ID=stipme
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http

# Mapbox
MAPBOX_ACCESS_TOKEN=

# Perspective API (moderation)
PERSPECTIVE_API_KEY=

VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
